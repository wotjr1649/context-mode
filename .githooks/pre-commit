#!/bin/sh
# Bundle-freshness guard (F55 decision, 2026-07-10).
#
# This fork keeps GitHub Actions dark. `assert-bundle` cannot catch a stale
# bundle (it only scans for the `__require("node:...")` shim), and the
# marketplace is autoUpdate: true — so a stale bundle is not a red CI light,
# it is old code silently running in production. This hook is the only line
# of defense.
#
# Blocks:
#   - bundle build failure
#   - unstaged stale bundle (the common case)
#   - staged stale bundle (the regenerated bytes differ from the index, so the
#     diff catches it)
#   - partial staging (source A in the index + source B in the worktree) — the
#     two-step check below
#
# Does NOT block (accepted, single-machine fork):
#   - `git commit --no-verify`
#   - a clone that never ran `git config core.hooksPath .githooks`
#   - commits made before this hook was installed (Tasks 1-10)
#
# ponytail: move this to CI once there are collaborators — pin esbuild to an
# exact version and commit package-lock.json so runners do not disagree.
set -e

# 1) Block partial staging. `npm run bundle` builds from the worktree while
#    `git diff` compares worktree-vs-index. If a bundle source differs between
#    the index and the worktree, "source A from the index + the regenerated
#    bundle B" would be committed and slip past the guard. (Codex review, Important 4)
if ! git diff --quiet -- src/ hooks/ start.mjs scripts/; then
  echo "pre-commit: bundle sources have unstaged changes." >&2
  echo "  The bundle is built from the worktree but you are committing the index." >&2
  echo "  Stage them ('git add -u') or stash them, then commit again." >&2
  git diff --name-only -- src/ hooks/ start.mjs scripts/ >&2
  exit 1
fi

# 2) Bundle freshness.
npm run bundle >/dev/null 2>&1 || {
  echo "pre-commit: 'npm run bundle' failed — fix the build before committing." >&2
  exit 1
}

if ! git diff --exit-code --quiet -- server.bundle.mjs cli.bundle.mjs 'hooks/*.bundle.mjs'; then
  echo "pre-commit: stale bundle(s) detected." >&2
  echo "  Run 'npm run build', stage the regenerated *.bundle.mjs, and commit again." >&2
  git diff --name-only -- server.bundle.mjs cli.bundle.mjs 'hooks/*.bundle.mjs' >&2
  exit 1
fi
